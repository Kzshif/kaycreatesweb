# Copy to .env.local and fill in.
# Required for the live AI surfaces (chatbot, SEO recommendations, AI writer,
# briefing, lead replies). Without it everything falls back to deterministic
# versions so you can still click through the whole product.
ANTHROPIC_API_KEY=

# Where the SQLite database lives. Defaults to ./data/kaycreatesweb.db.
# Use ":memory:" for an ephemeral store.
DATABASE_PATH=
