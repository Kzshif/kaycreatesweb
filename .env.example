# Copy to .env.local and fill in.
# Required for the live AI receptionist. Without it, the demo falls back to a
# scripted rule-based receptionist so you can still click through the product.
ANTHROPIC_API_KEY=

# Where the SQLite capture database lives. Defaults to ./data/frontdesk.db.
# Use ":memory:" for an ephemeral store.
DATABASE_PATH=

# --- Twilio voice (optional) ---
# If set, the /api/voice webhook validates Twilio's request signature.
TWILIO_AUTH_TOKEN=
# Public base URL Twilio should call back (e.g. https://your-app.example.com).
# Leave blank to use the request's own host.
PUBLIC_BASE_URL=
