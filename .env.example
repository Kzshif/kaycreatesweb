# Copy to .env.local and fill in.
# Required for the live AI receptionist. Without it, the demo falls back to a
# scripted rule-based receptionist so you can still click through the product.
ANTHROPIC_API_KEY=

# Which Claude model the receptionist uses. Defaults to claude-opus-4-8.
# To cut running costs, set claude-haiku-4-5 (cheapest) or claude-sonnet-4-6.
RECEPTIONIST_MODEL=

# Your live site URL — used for canonical links, sitemap, robots, and JSON-LD
# (AEO). Set this to your real deployed URL for best AI-search results.
NEXT_PUBLIC_SITE_URL=

# --- Stripe checkout (pricing buttons) ---
# Paste the Stripe Payment Link URL for each plan here. The pricing buttons read
# these directly, so swapping test → live is just changing the URL (no code
# change). If a value is blank, that button falls back to the demo.
NEXT_PUBLIC_STRIPE_STARTER_URL=
NEXT_PUBLIC_STRIPE_PRACTICE_URL=
# Optional: turns the Group plan's "Contact us" button into a mailto.
NEXT_PUBLIC_CONTACT_EMAIL=

# --- Twilio voice (optional) ---
# If set, the /api/voice webhook validates Twilio's request signature.
TWILIO_AUTH_TOKEN=
# Public base URL Twilio should call back (e.g. https://your-site.netlify.app).
# Leave blank to use the request's own host.
PUBLIC_BASE_URL=
