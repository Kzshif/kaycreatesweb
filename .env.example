# Copy to .env.local and fill in.
# Required for the live AI surfaces (chatbot, SEO recommendations, AI writer,
# briefing, lead replies). Without it everything falls back to deterministic
# versions so you can still click through the whole product.
ANTHROPIC_API_KEY=

# Permanent database. On Netlify, provision Netlify DB and NETLIFY_DATABASE_URL
# is injected automatically; anywhere else, set DATABASE_URL to any postgres://
# connection string (Neon, Supabase, RDS…). With neither set, the app runs on
# local SQLite (./data/kaycreatesweb.db, or DATABASE_PATH if provided).
DATABASE_URL=
DATABASE_PATH=
