{
  "intervalSeconds": 300,
  "jitterSeconds": 60,
  "perRequestDelayMs": 3000,
  "requestTimeoutMs": 20000,
  "stateFile": "state.uk.json",

  "notify": {
    "discordWebhookUrl": "",
    "telegramBotToken": "",
    "telegramChatId": ""
  },

  "_comment": "UK-wide sweep for Pokémon ETBs, booster bundles and booster boxes. Category watches scan a shop's whole Pokémon section and alert when NEW products matching the keywords appear (first pass seeds silently). Specialist TCG shops are enabled out of the box; big-box retailers are included but disabled — verify their section URL loads in your browser, then enable (add browser:true if a watch always finds 0 matches). Copy to uk-watches.json, add your webhook, then run: node checker.mjs --config uk-watches.json",

  "watches": [
    {
      "id": "cat-chaoscards",
      "name": "Chaos Cards — Pokémon sealed",
      "store": "Chaos Cards (UK online)",
      "url": "https://www.chaoscards.co.uk/shop/card-games/pokemon",
      "mode": "category",
      "keywords": ["elite trainer box", "booster bundle", "booster box"],
      "excludeText": ["japanese", "single"],
      "enabled": true
    },
    {
